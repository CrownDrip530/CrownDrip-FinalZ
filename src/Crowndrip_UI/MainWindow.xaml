<Window x:Class="Crowndrip_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrownDrip Executor v2 - Safe Build"
        Height="500"
        Width="800"
        Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#252526">
            <Menu Background="Transparent" Foreground="#FFFFFF" Margin="5,0,0,0">
                <MenuItem Header="File" Foreground="#FFFFFF">
                    <MenuItem Header="Open Script" Foreground="#000000"/>
                    <MenuItem Header="Save Script" Foreground="#000000"/>
                </MenuItem>
            </Menu>
        </StackPanel>

        <TextBox x:Name="ScriptTextBox"
                 Grid.Row="1"
                 Margin="10"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 BorderBrush="#3F3F3F"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="14"
                 AcceptsTab="True"
                 Text="-- Safe build&#x0a;print('UI initialized')"/>

        <Grid Grid.Row="2" Background="#007ACC">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label x:Name="StatusLabel"
                   Grid.Column="0"
                   Content="Status: Ready"
                   Foreground="#FFFFFF"
                   VerticalAlignment="Center"
                   Margin="15,0,0,0"
                   FontWeight="Bold"/>

            <Button x:Name="ExecuteButton"
                    Grid.Column="1"
                    Content="Execute"
                    Width="120"
                    Height="30"
                    Margin="0,0,15,0"
                    Background="#252526"
                    Foreground="#FFFFFF"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="ExecuteButton_Click"/>
        </Grid>
    </Grid>
</Window>
